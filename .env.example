# ─────────────────────────────────────────────────────────────────────────────
# Compound OS — environment variables
#
# Copy this file to .env.local and fill in the values. Never commit
# .env.local. Each variable is documented below with where to find it.
#
# Convention: NEXT_PUBLIC_* vars are exposed to the browser. Anything
# without that prefix is server-only and MUST NEVER appear in client
# bundles. The runtime env validator (app/lib/env.ts) fails the deploy
# if any required var is missing in production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ───────────────────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard.
# The URL and ANON key are safe to expose to the browser. The
# SERVICE_ROLE key bypasses Row Level Security and must NEVER be
# exposed to the client. Used by server routes only.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...public-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...SERVICE-ROLE-key-SERVER-ONLY...

# ── Stripe ─────────────────────────────────────────────────────────────────
# Developers → API keys. Use sk_test_* locally and sk_live_* in production.
STRIPE_SECRET_KEY=sk_test_...

# Developers → Webhooks → your endpoint's "Signing secret" (whsec_...).
# DIFFERENT per endpoint. Local `stripe listen` prints its own temporary
# secret; the prod webhook in the dashboard has its own permanent one.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Session cookie ─────────────────────────────────────────────────────────
# Signs the cos_session cookie. Generate once with:
#   openssl rand -base64 48
# Keep it long and random. Rotating it invalidates every existing session
# (users will have to log in again). Minimum 32 chars enforced at runtime.
COS_SESSION_SECRET=REPLACE-WITH-long-random-48-byte-base64-string

# ── Email (Resend) ─────────────────────────────────────────────────────────
# resend.com → API Keys. Optional in dev: if RESEND_API_KEY is missing,
# welcome emails are silently skipped. Required in production.
RESEND_API_KEY=re_...

# Bare email of your verified sender in Resend. The code wraps this in a
# display name automatically, so "tarek@thecompoundsystem.com" will render
# as "Compound OS <tarek@thecompoundsystem.com>" in inboxes.
EMAIL_FROM=tarek@thecompoundsystem.com

# ── Site URL ───────────────────────────────────────────────────────────────
# Public URL for this deployment. Used for Stripe redirect URLs and links
# inside emails. Set to http://localhost:3000 locally, https://... in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Google Search Console verification (optional) ──────────────────────────
# Search Console → Settings → Ownership verification → HTML tag method →
# copy the content="..." value. Lets us verify domain ownership without
# pushing a new HTML file each time.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Sentry (production only) ───────────────────────────────────────────────
# sentry.io → your project → Settings → Client Keys → DSN.
# Public — exposed to the browser so client errors phone home.
NEXT_PUBLIC_SENTRY_DSN=

# Source-map upload during build. Set in Vercel build env, not runtime.
# org / project slugs from your Sentry URL. Auth token is private.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Conversion pixels (production only — see docs/conversion-pixels.md) ────
# Meta (Facebook + Instagram). Pixel ID is public; CAPI access token is
# server-only and must never be NEXT_PUBLIC_.
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# Google Ads. Conversion ID (AW-...) is public. Optional purchase label
# pinpoints which conversion to attribute the Purchase event to.
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_PURCHASE_LABEL=

# TikTok. Pixel ID is public; Events API token is server-only.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
TIKTOK_EVENTS_API_TOKEN=
